    "drizzle-orm": "^0.44.5",
    "express": "^4.21.2",
    "jose": "^6.1.0",
    "nanoid": "^5.1.5",
    "pg": "^8.11.0",
    "superjson": "^1.13.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.31.4",
